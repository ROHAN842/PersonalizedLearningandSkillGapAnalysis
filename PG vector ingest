# code for skipping duplicates
###this means basically if we are doing some changes in pdf and using the same refernce id it will not get ingest in vector db 
###as the refernce id is same. so it will skip ingesting and give the retriving from previous saved embeddings
def normalize_text(text: str) -> str:
    """Normalize whitespace so same text always hashes the same"""
    return " ".join(text.strip().split())


def compute_content_hash(text: str) -> str:
    """
    Hash used for deduplication per reference_id.
    """
    return hashlib.sha256(normalize_text(text).encode("utf-8")).hexdigest()

