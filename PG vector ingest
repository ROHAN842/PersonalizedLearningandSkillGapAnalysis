# updated code with insertion in attachment info table
async def run_mcp(reference_id, document_type, blob_url, blob_name):
    try:
        # 1. Resolve blob + ingest chunks
        account, container, blob = resolve_blob(blob_url, blob_name)
        ingest(reference_id, account, container, blob)

        # ✅ 2. Store attachment metadata
        insert_attachment_info(
            reference_id=reference_id,
            blob_url=blob_url,
            document_type=document_type
        )

        # 3. Run extraction
        extraction = await process_retrieval_pg(
            reference_id=reference_id,
            document_type=document_type,
        )

        return extraction

    except Exception as e:
        return {
            "extracted": False,
            "reference_id": reference_id,
            "document_type": document_type,
            "error_message": str(e),
        }

