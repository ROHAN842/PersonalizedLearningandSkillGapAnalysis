def read_txt_from_blob(account_url: str, container: str, blob_name: str) -> str:
    conn_str = os.getenv("AZURE_STORAGE_CONNECTION_STRING_PGVECTOR")
    if not conn_str:
        raise RuntimeError("AZURE_STORAGE_CONNECTION_STRING not set")

    bc = BlobClient.from_connection_string(
        conn_str=conn_str,
        container_name=container,
        blob_name=blob_name
    )
    return bc.download_blob().readall().decode("utf-8")


# ─────────────────────────────────────────────
# TEXT → CHUNKS
# ─────────────────────────────────────────────
def chunk_text(text: str):
    clean = " ".join(text.split())
    chunks = []
    start, idx = 0, 0

    while start < len(clean):
        end = min(start + CHUNK_CHARS, len(clean))
        part = clean[start:end]
        if part.strip():
            chunks.append((1, idx, part))
            idx += 1
        start = end - OVERLAP_CHARS if end < len(clean) else end

    return chunks


