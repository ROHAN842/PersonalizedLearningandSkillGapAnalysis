def already_ingested(reference_id: str, attachment_id: str) -> bool:
    with get_chunk_conn() as conn:
        # ✅ Ensure table exists BEFORE querying
        ensure_pgvector_table(conn)

        with conn.cursor() as cur:
            cur.execute(
                f"""
                SELECT 1
                FROM {DB_SCHEMA}.{DB_TABLE}
                WHERE mail_ref_id=%s AND attachment_id=%s
                LIMIT 1
                """,
                (reference_id, attachment_id)
            )
            return cur.fetchone() is not None


