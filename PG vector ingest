### code for skipping duplicates 
def ensure_pgvector_table(conn):
    with conn.cursor() as cur:
        cur.execute("CREATE EXTENSION IF NOT EXISTS vector;")
        cur.execute(f"""
        CREATE TABLE IF NOT EXISTS {DB_SCHEMA}.{DB_TABLE} (
            id BIGSERIAL PRIMARY KEY,
            doc_id TEXT NOT NULL,
            source TEXT NOT NULL,
            page INT NOT NULL,
            chunk_index INT NOT NULL,
            content TEXT NOT NULL,
            content_hash TEXT NOT NULL,
            embedding VECTOR({EMBED_DIM}) NOT NULL,
            metadata JSONB,
            mail_ref_id TEXT,
            attachment_id TEXT,

            -- ✅ Dedup ONLY per reference_id
            UNIQUE (mail_ref_id, content_hash),

            -- ✅ Keep old safety constraint
            UNIQUE (mail_ref_id, attachment_id, page, chunk_index)
        );
        """)
    conn.commit()

# for skipping duplicates 
def chunk_exists(conn, reference_id: str, content_hash: str) -> bool:
    with conn.cursor() as cur:
        cur.execute(
            f"""
            SELECT 1
            FROM {DB_SCHEMA}.{DB_TABLE}
            WHERE mail_ref_id = %s
              AND content_hash = %s
            LIMIT 1
            """,
            (reference_id, content_hash),
        )
        return cur.fetchone() is not None

